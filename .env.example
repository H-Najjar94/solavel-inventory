APP_NAME=SolaStock
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_RAW_ERRORS=false
APP_URL=https://solavel.com/inventory
ASSET_URL=https://solavel.com/inventory

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (database-per-tenant; mirrors solavel-finance) ────────────────
# 'tenant' is the default connection; its database is swapped at runtime.
# 'mysql' is the central/landlord connection (tenant registry).
# Inventory uses its OWN databases — never Finance's.
DB_CONNECTION=tenant
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=solavel_inventory
DB_USERNAME=mysql
DB_PASSWORD=

# ── Tenant connection ─────────────────────────────────────────────────────
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_CHARSET=utf8mb4
TENANT_DB_COLLATION=utf8mb4_unicode_ci
TENANT_DB_USER_HOST=%
# Production tenant DB prefix → inventory_tenant_000123
TENANT_DB_PREFIX=inventory_tenant_
TENANT_DB_PAD=6

# ── Tenant admin (CREATE DATABASE/USER/GRANT) ─────────────────────────────
TENANT_DB_ADMIN_USER=mysql
TENANT_DB_ADMIN_PASS=

# Secret used to derive per-tenant DB credentials (tenant_dynamic). Generate a
# fresh 64+ char random value per environment; never commit a real one.
TENANT_DERIVE_SECRET=

# Optional dual-secret rotation support (#35, mirrors SolaBooks #30 / SolaProjects
# #33 / SolaHR #34) — leave UNSET in normal operation. Behavior is identical to
# single-secret until TENANT_DERIVE_PREVIOUS_SECRET is set. During a future,
# owner-approved rotation window only: set the FORMER secret here so connections
# can be verified/fallen back against the previous derivation. Ignored unless >=32
# chars and != primary. Setting it does NOT rotate anything by itself.
# TENANT_DERIVE_PREVIOUS_SECRET=
# Non-sensitive label for safe logging/metrics (default v1):
# TENANT_DERIVE_SECRET_VERSION=v1

# Tenant provisioning + migration marker (Finance parity)
TENANT_PROVISION_LOCK_SECONDS=300
TENANT_PROVISION_LOCK_WAIT=30
TENANT_LANDLORD_ENABLED=false
TENANT_MIGRATION_MARKER_KEY=migrated_at_inv

# Connection-name aliases (Finance parity)
CENTRAL_CONNECTION=mysql
TENANT_CONNECTION=tenant

# ── Session (subpath-scoped, like the other Solavel sub-apps) ─────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=solavel_inventory_session
SESSION_PATH=/inventory
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_DB_CONNECTION=tenant
CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@solavel.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Central / SSO (Solavel suite parity; fill per environment) ─────────────
CENTRAL_APP_URL=https://solavel.com
PARENT_BASE_URL=https://solavel.com
APP_URL_INVENTORY=https://solavel.com/inventory
SSO_SHARED_SECRET=
SSO_CALLBACK_ROUTE=/sso/callback

VITE_APP_NAME="${APP_NAME}"
