# SolaStock test environment — PLACEHOLDERS ONLY. Never commit real passwords.
#
# Finance/Projects-style FIXED reserved test databases (pre-provisioned; the
# suite NEVER creates or drops them):
#   tenant_990001 = Finance      → NEVER used by SolaStock
#   tenant_990002 = Projects     → NEVER used by SolaStock
#   tenant_990010 = SolaStock tenant A   (default active tenant)
#   tenant_990011 = SolaStock tenant B   (isolation tests switch to this)
#   tenant_990012 = SolaStock central/landlord
#
# Central ('mysql') and tenant ('tenant') resolve to DISTINCT databases.
# Uses the existing Finance-compatible 'mysql' MySQL account (auth_socket), so
# the test command must run as the 'mysql' OS user. No new MySQL user needed.

APP_ENV=testing
APP_DEBUG=true
APP_KEY=

# Default connection = tenant (Finance/Projects parity)
DB_CONNECTION=tenant

# Central / landlord connection → tenant_990012
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tenant_990012
DB_USERNAME=mysql
DB_PASSWORD=

CENTRAL_CONNECTION=mysql
TENANT_CONNECTION=tenant

# Active tenant connection → tenant_990010 (tenant A)
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_DATABASE=tenant_990010
TENANT_DB_CHARSET=utf8mb4
TENANT_DB_COLLATION=utf8mb4_unicode_ci

# Reserved DB names consumed by the test harness (Tests\Support\TenantTestManager)
SOLASTOCK_TEST_TENANT_A=tenant_990010
SOLASTOCK_TEST_TENANT_B=tenant_990011
SOLASTOCK_TEST_CENTRAL=tenant_990012

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BCRYPT_ROUNDS=4
