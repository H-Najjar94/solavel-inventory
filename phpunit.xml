<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- SolaStock tenancy tests run against MySQL (db-per-tenant), NEVER sqlite.
             FIXED reserved databases (Finance/Projects-style; never created/
             dropped here):
               * central  'mysql'  → tenant_990012
               * tenant   'tenant' → tenant_990010 (tenant A; isolation tests
                                       switch to tenant_990011 = tenant B)
               * tenant_990001 = Finance, tenant_990002 = Projects — never used.
             Central and tenant are DISTINCT databases. Credentials come from
             .env.testing (Finance-compatible 'mysql' auth_socket user). The
             safety guard allows ONLY tenant_990010/11/12 before any DB action. -->
        <env name="DB_CONNECTION" value="tenant"/>
        <env name="CENTRAL_CONNECTION" value="mysql"/>
        <env name="TENANT_CONNECTION" value="tenant"/>
        <env name="DB_DATABASE" value="tenant_990012"/>
        <env name="TENANT_DB_DATABASE" value="tenant_990010"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
